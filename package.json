{
  "name": "@ossdotnow/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "types": "./src/root.ts",
  "exports": {
    ".": {
      "types": "./src/root.ts",
      "default": "./src/root.ts"
    },
    "./uploadthing": {
      "types": "./src/uploadthing.ts",
      "default": "./src/uploadthing.ts"
    }
  },
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "start": "bun src/server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "smoke": "bun smoke/api-smoke.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3",
    "@better-auth/drizzle-adapter": "1.6.9",
    "@hono/node-server": "^1.13.8",
    "@octokit/core": "^7.0.2",
    "@octokit/plugin-rest-endpoint-methods": "^16.0.0",
    "@trpc/server": "^11.4.2",
    "@unkey/ratelimit": "^2.0.0",
    "@upstash/redis": "^1.35.1",
    "ai": "^6",
    "better-auth": "1.6.9",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.2",
    "hono": "^4.7.11",
    "postgres": "^3.4.7",
    "resend": "^6.12.2",
    "superjson": "^2.2.2",
    "uploadthing": "^7.7.2",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/node": "^24",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.29.0",
    "globals": "^16.2.0",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.33.1"
  },
  "engines": {
    "bun": ">=1.2.13"
  },
  "packageManager": "bun@1.3.4"
}
